generator client {
  provider = "prisma-client-js"
}

generator dbml {
  provider = "prisma-dbml-generator"
  output   = "./dbml"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String        @id @default(cuid())
  name                   String?
  email                  String        @unique
  password               String
  emailVerified          DateTime?
  image                  String?
  phone                  String?
  locale                 String        @default("en")
  timezone               String        @default("UTC")
  currency               String        @default("EUR")
  stripeConnectAccountId String?       @unique // Stripe Connect account for receiving 80% of subscription revenue
  stripeConnectOnboarded Boolean       @default(false) // Track if Connect onboarding is complete
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  accounts               Account[]
  alerts                 Alert[]
  business               Business?
  subscription           Subscription?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Business {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  address   String?
  city      String?
  country   String?
  phone     String?
  email     String?
  logo      String?
  website   String?
  currency  String   @default("EUR")
  timezone  String   @default("UTC")
  locale    String   @default("en")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stores    Store[]

  @@map("businesses")
}

model Store {
  id                String            @id @default(cuid())
  businessId        String
  name              String
  address           String?
  city              String?
  country           String?
  phone             String?
  email             String?
  image             String?
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  ingredients       Material[]
  orders            Order[]
  productionBatches ProductionBatch[]
  products          Product[]
  recipes           Recipe[]
  business          Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplierOrders    SupplierOrder[]
  suppliers         Supplier[]

  @@index([businessId])
  @@index([isActive])
  @@map("stores")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 SubscriptionPlan   @default(STARTER)
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Product {
  id                String            @id @default(cuid())
  sku               String
  name              String
  description       String?
  category          String?
  costPrice         Decimal           @db.Decimal(10, 2)
  sellingPrice      Decimal           @db.Decimal(10, 2)
  currentStock      Decimal           @default(0) @db.Decimal(10, 2)
  unit              String            @default("piece")
  productionTime    Int?
  shelfLife         Int?
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  storeId           String
  maxStock          Decimal           @default(1000) @db.Decimal(10, 2)
  minStock          Decimal           @default(0) @db.Decimal(10, 2)
  orderItems        OrderItem[]
  productionBatches ProductionBatch[]
  store             Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  stockMovements    StockMovement[]
  recipeProducts    RecipeProduct[]

  @@unique([storeId, sku])
  @@index([storeId])
  @@index([category])
  @@index([isActive])
  @@map("products")
}

model Material {
  id                 String              @id @default(cuid())
  sku                String
  name               String
  description        String?
  category           String?
  unit               String              @default("kg")
  unitCost           Decimal             @db.Decimal(10, 2)
  currentStock       Decimal             @default(0) @db.Decimal(10, 2)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  maxStock           Decimal             @default(1000) @db.Decimal(10, 2)
  minStock           Decimal             @default(0) @db.Decimal(10, 2)
  storeId            String
  materialSuppliers  MaterialSupplier[]  @relation("MaterialToSuppliers")
  store              Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  recipeIngredients  RecipeIngredient[]
  stockMovements     StockMovement[]
  supplierOrderItems SupplierOrderItem[]

  @@unique([storeId, sku])
  @@index([storeId])
  @@index([category])
  @@index([isActive])
  @@map("ingredients")
}

model MaterialSupplier {
  id          String   @id @default(cuid())
  supplierId  String
  price       Decimal  @db.Decimal(10, 2)
  isPreferred Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  materialId  String
  material    Material @relation("MaterialToSuppliers", fields: [materialId], references: [id], onDelete: Cascade)
  supplier    Supplier @relation("SupplierToMaterials", fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([materialId, supplierId])
  @@index([materialId])
  @@index([supplierId])
  @@map("ingredient_suppliers")
}

model Recipe {
  id                    String             @id @default(cuid())
  instructions          String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  storeId               String
  category              String?
  costPerBatch          Decimal            @default(0) @db.Decimal(10, 2)
  description           String?
  name                  String
  productionTimeMinutes Int
  yieldQuantity         Decimal            @db.Decimal(10, 2)
  yieldUnit             String
  productionBatches     ProductionBatch[]
  ingredients           RecipeIngredient[]
  recipeProducts        RecipeProduct[]
  store                 Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([category])
  @@map("recipes")
}

model RecipeIngredient {
  id         String   @id @default(cuid())
  recipeId   String
  quantity   Decimal  @db.Decimal(10, 3)
  unit       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  notes      String?
  materialId String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, materialId])
  @@map("recipe_ingredients")
}

model RecipeProduct {
  id        String   @id @default(cuid())
  recipeId  String
  productId String
  isDefault Boolean  @default(false) // Indicates if this is the default recipe for this product
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([recipeId, productId])
  @@index([recipeId])
  @@index([productId])
  @@map("recipe_products")
}

model ProductionBatch {
  id              String           @id @default(cuid())
  batchNumber     String           @unique
  productId       String
  recipeId        String?
  plannedQuantity Decimal          @db.Decimal(10, 2)
  actualQuantity  Decimal?         @db.Decimal(10, 2)
  unit            String
  status          ProductionStatus @default(PLANNED)
  scheduledDate   DateTime
  completedDate   DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  storeId         String
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  recipe          Recipe?          @relation(fields: [recipeId], references: [id])
  store           Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  stockMovements  StockMovement[]

  @@index([storeId])
  @@index([productId])
  @@index([status])
  @@index([scheduledDate])
  @@map("production_batches")
}

model StockMovement {
  id                String           @id @default(cuid())
  productId         String?
  type              MovementType
  quantity          Decimal          @db.Decimal(10, 3)
  unit              String
  balanceAfter      Decimal          @db.Decimal(10, 3)
  orderId           String?
  productionBatchId String?
  notes             String?
  createdAt         DateTime         @default(now())
  materialId        String?
  material          Material?        @relation(fields: [materialId], references: [id], onDelete: Cascade)
  order             Order?           @relation(fields: [orderId], references: [id])
  product           Product?         @relation(fields: [productId], references: [id], onDelete: Cascade)
  productionBatch   ProductionBatch? @relation(fields: [productionBatchId], references: [id])

  @@index([productId])
  @@index([materialId])
  @@index([type])
  @@index([createdAt])
  @@map("stock_movements")
}

model Supplier {
  id                String             @id @default(cuid())
  name              String
  contactPerson     String?
  email             String?
  phone             String?
  address           String?
  city              String?
  country           String?
  notes             String?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  storeId           String
  materialSuppliers MaterialSupplier[] @relation("SupplierToMaterials")
  supplierOrders    SupplierOrder[]
  store             Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([isActive])
  @@map("suppliers")
}

model SupplierOrder {
  id           String              @id @default(cuid())
  storeId      String
  supplierId   String
  orderNumber  String              @unique
  status       SupplierOrderStatus @default(PENDING)
  orderDate    DateTime            @default(now())
  expectedDate DateTime?
  receivedDate DateTime?
  subtotal     Decimal             @db.Decimal(10, 2)
  tax          Decimal             @default(0) @db.Decimal(10, 2)
  shipping     Decimal             @default(0) @db.Decimal(10, 2)
  total        Decimal             @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  items        SupplierOrderItem[]
  store        Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  supplier     Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@map("supplier_orders")
}

model SupplierOrderItem {
  id         String        @id @default(cuid())
  orderId    String
  materialId String
  quantity   Decimal       @db.Decimal(10, 2)
  unit       String
  unitPrice  Decimal       @db.Decimal(10, 2)
  total      Decimal       @db.Decimal(10, 2)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  material   Material      @relation(fields: [materialId], references: [id], onDelete: Cascade)
  order      SupplierOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([materialId])
  @@map("supplier_order_items")
}

model Order {
  id              String          @id @default(cuid())
  orderNumber     String          @unique
  customerName    String
  customerEmail   String?
  customerPhone   String?
  deliveryAddress String?
  status          OrderStatus     @default(PENDING)
  orderDate       DateTime        @default(now())
  dueDate         DateTime?
  deliveredDate   DateTime?
  subtotal        Decimal         @db.Decimal(10, 2)
  tax             Decimal         @default(0) @db.Decimal(10, 2)
  delivery        Decimal         @default(0) @db.Decimal(10, 2)
  total           Decimal         @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  storeId         String
  items           OrderItem[]
  store           Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  stockMovements  StockMovement[]

  @@index([storeId])
  @@index([status])
  @@index([orderDate])
  @@index([dueDate])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Decimal  @db.Decimal(10, 2)
  unit      String
  unitPrice Decimal  @db.Decimal(10, 2)
  total     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model Alert {
  id         String        @id @default(cuid())
  userId     String
  type       AlertType
  severity   AlertSeverity @default(INFO)
  title      String
  message    String
  entityType String?
  entityId   String?
  isRead     Boolean       @default(false)
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([type])
  @@index([createdAt])
  @@map("alerts")
}

model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency String // Base currency (EUR)
  toCurrency   String // Target currency (USD)
  rate         Decimal  @db.Decimal(10, 6) // Exchange rate with 6 decimal precision
  fetchedAt    DateTime @default(now()) // When the rate was fetched
  expiresAt    DateTime // When the cached rate expires
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([fromCurrency, toCurrency])
  @@index([expiresAt])
  @@map("exchange_rates")
}

enum SubscriptionPlan {
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  INCOMPLETE
}

enum ProductionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MovementType {
  PURCHASE
  PRODUCTION_IN
  PRODUCTION_OUT
  SALE
  ADJUSTMENT
  WASTE
}

enum SupplierOrderStatus {
  PENDING
  PLACED
  RECEIVED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  READY
  DELIVERED
  CANCELLED
}

enum AlertType {
  LOW_STOCK
  CRITICAL_STOCK
  ORDER_DUE
  PRODUCTION_DUE
  SYSTEM
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}
