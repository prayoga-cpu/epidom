generator client {
  provider = "prisma-client-js"
}

generator dbml {
  provider = "prisma-dbml-generator"
  output   = "./dbml"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String        @id @default(cuid())
  name                   String
  email                  String        @unique
  emailVerified          Boolean
  image                  String?
  createdAt              DateTime
  updatedAt              DateTime
  // Custom fields
  phone                  String?
  locale                 String        @default("id")
  timezone               String        @default("Asia/Jakarta")
  currency               String        @default("IDR")
  stripeConnectAccountId String?
  stripeConnectOnboarded Boolean       @default(false)
  isAdmin                Boolean       @default(false)
  hasOnboarded           Boolean       @default(false)

  sessions               Session[]
  accounts               Account[]
  alerts                 Alert[]
  business               Business?
  subscription           Subscription?

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Business {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String
  address   String?
  city      String?
  country   String?
  phone     String?
  email     String?
  logo      String?
  website   String?
  currency  String   @default("IDR")
  timezone  String   @default("Asia/Jakarta")
  locale    String   @default("id")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stores    Store[]

  @@map("businesses")
}

model Store {
  id                String            @id @default(cuid())
  businessId        String
  name              String
  address           String?
  city              String?
  country           String?
  phone             String?
  email             String?
  image             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  ingredients       Material[]
  orders            Order[]
  productionBatches ProductionBatch[]
  products          Product[]
  recipes           Recipe[]
  business          Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  supplierOrders    SupplierOrder[]
  suppliers         Supplier[]
  aiImportMemories  AIImportMemory[]
  aiImportSessions  AIImportSession[]
  storefront              Storefront?
  tables                  Table[]
  staffMembers            StaffMember[]
  shifts                  Shift[]
  reservations            Reservation[]
  aggregatorConnections   AggregatorConnection[]
  aggregatorEmails        AggregatorEmail[]

  @@index([businessId])
  @@map("stores")
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String             @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(INCOMPLETE)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model Product {
  id                String            @id @default(cuid())
  sku               String
  name              String
  description       String?
  category          String?
  costPrice         Decimal           @db.Decimal(10, 2)
  sellingPrice      Decimal           @db.Decimal(10, 2)
  currentStock      Decimal           @default(0) @db.Decimal(10, 2)
  unit              String            @default("piece")
  productionTime    Int?
  shelfLife         Int?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  storeId           String
  maxStock          Decimal           @default(1000) @db.Decimal(10, 2)
  minStock          Decimal           @default(0) @db.Decimal(10, 2)
  orderItems        OrderItem[]
  productionBatches ProductionBatch[]
  store             Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  recipeProducts    RecipeProduct[]
  stockMovements    StockMovement[]
  menuItems         MenuItem[]

  @@unique([storeId, sku])
  @@index([storeId])
  @@index([category])
  @@map("products")
}

model Material {
  id                 String              @id @default(cuid())
  sku                String
  name               String
  description        String?
  category           String?
  unit               String              @default("kg")
  unitCost           Decimal             @db.Decimal(10, 2)
  currentStock       Decimal             @default(0) @db.Decimal(10, 2)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  maxStock           Decimal             @default(1000) @db.Decimal(10, 2)
  minStock           Decimal             @default(0) @db.Decimal(10, 2)
  storeId            String
  materialSuppliers  MaterialSupplier[]  @relation("MaterialToSuppliers")
  store              Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  recipeIngredients  RecipeIngredient[]
  stockMovements     StockMovement[]
  supplierOrderItems SupplierOrderItem[]

  @@unique([storeId, sku])
  @@index([storeId])
  @@index([category])
  @@map("ingredients")
}

model MaterialSupplier {
  id          String   @id @default(cuid())
  supplierId  String
  price       Decimal  @db.Decimal(10, 2)
  isPreferred Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  materialId  String
  material    Material @relation("MaterialToSuppliers", fields: [materialId], references: [id], onDelete: Cascade)
  supplier    Supplier @relation("SupplierToMaterials", fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([materialId, supplierId])
  @@index([materialId])
  @@index([supplierId])
  @@map("ingredient_suppliers")
}

model Recipe {
  id                    String             @id @default(cuid())
  instructions          String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  storeId               String
  category              String?
  costPerBatch          Decimal            @default(0) @db.Decimal(10, 2)
  description           String?
  name                  String
  productionTimeMinutes Int
  yieldQuantity         Decimal            @db.Decimal(10, 2)
  yieldUnit             String
  productionBatches     ProductionBatch[]
  ingredients           RecipeIngredient[]
  recipeProducts        RecipeProduct[]
  store                 Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([category])
  @@map("recipes")
}

model RecipeIngredient {
  id         String   @id @default(cuid())
  recipeId   String
  quantity   Decimal  @db.Decimal(10, 3)
  unit       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  notes      String?
  materialId String
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  recipe     Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, materialId])
  @@map("recipe_ingredients")
}

model RecipeProduct {
  id        String   @id @default(cuid())
  recipeId  String
  productId String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, productId])
  @@index([recipeId])
  @@index([productId])
  @@map("recipe_products")
}

model ProductionBatch {
  id              String           @id @default(cuid())
  batchNumber     String           @unique
  productId       String
  recipeId        String?
  plannedQuantity Decimal          @db.Decimal(10, 2)
  actualQuantity  Decimal?         @db.Decimal(10, 2)
  unit            String
  status          ProductionStatus @default(PLANNED)
  scheduledDate   DateTime
  completedDate   DateTime?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  storeId         String
  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  recipe          Recipe?          @relation(fields: [recipeId], references: [id])
  store           Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  stockMovements  StockMovement[]

  @@index([storeId])
  @@index([productId])
  @@index([status])
  @@index([scheduledDate])
  @@map("production_batches")
}

model StockMovement {
  id                String           @id @default(cuid())
  productId         String?
  type              MovementType
  quantity          Decimal          @db.Decimal(10, 3)
  unit              String
  balanceAfter      Decimal          @db.Decimal(10, 3)
  orderId           String?
  productionBatchId String?
  notes             String?
  createdAt         DateTime         @default(now())
  materialId        String?
  reason            String?
  referenceId       String?
  material          Material?        @relation(fields: [materialId], references: [id], onDelete: Cascade)
  order             Order?           @relation(fields: [orderId], references: [id])
  product           Product?         @relation(fields: [productId], references: [id], onDelete: Cascade)
  productionBatch   ProductionBatch? @relation(fields: [productionBatchId], references: [id])

  @@index([productId])
  @@index([materialId])
  @@index([type])
  @@index([createdAt])
  @@map("stock_movements")
}

model Supplier {
  id                String             @id @default(cuid())
  name              String
  contactPerson     String?
  email             String?
  phone             String?
  address           String?
  city              String?
  country           String?
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  storeId           String
  materialSuppliers MaterialSupplier[] @relation("SupplierToMaterials")
  supplierOrders    SupplierOrder[]
  store             Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@map("suppliers")
}

model SupplierOrder {
  id           String              @id @default(cuid())
  storeId      String
  supplierId   String
  orderNumber  String              @unique
  status       SupplierOrderStatus @default(PENDING)
  orderDate    DateTime            @default(now())
  expectedDate DateTime?
  receivedDate DateTime?
  subtotal     Decimal             @db.Decimal(10, 2)
  tax          Decimal             @default(0) @db.Decimal(10, 2)
  shipping     Decimal             @default(0) @db.Decimal(10, 2)
  total        Decimal             @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  items        SupplierOrderItem[]
  store        Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  supplier     Supplier            @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([supplierId])
  @@index([status])
  @@index([orderDate])
  @@map("supplier_orders")
}

model SupplierOrderItem {
  id         String        @id @default(cuid())
  orderId    String
  materialId String
  quantity   Decimal       @db.Decimal(10, 2)
  unit       String
  unitPrice  Decimal       @db.Decimal(10, 2)
  total      Decimal       @db.Decimal(10, 2)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  material   Material      @relation(fields: [materialId], references: [id], onDelete: Cascade)
  order      SupplierOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([materialId])
  @@map("supplier_order_items")
}

model Order {
  id                  String          @id @default(cuid())
  orderNumber         String          @unique
  customerName        String
  customerEmail       String?
  customerPhone       String?
  deliveryAddress     String?
  status              OrderStatus     @default(PENDING)
  orderDate           DateTime        @default(now())
  dueDate             DateTime?
  deliveredDate       DateTime?
  subtotal            Decimal         @db.Decimal(10, 2)
  tax                 Decimal         @default(0) @db.Decimal(10, 2)
  delivery            Decimal         @default(0) @db.Decimal(10, 2)
  total               Decimal         @db.Decimal(10, 2)
  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  storeId             String
  // Phase 2 fields
  storefrontId        String?
  orderType           OrderType       @default(DINE_IN)
  tableNumber         String?
  paymentMethod       PaymentMethod   @default(CASH)
  paymentStatus       PaymentStatus   @default(PENDING)
  paymentProviderRef  String?
  source              OrderSource     @default(MANUAL)
  // Phase 3 fields
  tableId             String?
  // Phase 4 fields
  shiftId             String?
  items               OrderItem[]
  store               Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storefront          Storefront?     @relation(fields: [storefrontId], references: [id], onDelete: SetNull)
  table               Table?          @relation(fields: [tableId], references: [id], onDelete: SetNull)
  shift               Shift?          @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  stockMovements      StockMovement[]

  @@index([storeId])
  @@index([status])
  @@index([orderDate])
  @@index([dueDate])
  @@index([storefrontId])
  @@index([paymentStatus])
  @@index([tableId])
  @@index([shiftId])
  @@map("orders")
}

model OrderItem {
  id         String          @id @default(cuid())
  orderId    String
  productId  String?
  menuItemId String?
  name       String          @default("")
  quantity   Decimal         @db.Decimal(10, 2)
  unit       String
  unitPrice  Decimal         @db.Decimal(10, 2)
  total      Decimal         @db.Decimal(10, 2)
  // Phase 3: KDS workflow
  status     OrderItemStatus @default(PENDING)
  preparedAt DateTime?
  servedAt   DateTime?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product    Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  menuItem   MenuItem?       @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@index([menuItemId])
  @@index([status])
  @@map("order_items")
}

model Alert {
  id         String        @id @default(cuid())
  userId     String
  type       AlertType
  severity   AlertSeverity @default(INFO)
  title      String
  message    String
  entityType String?
  entityId   String?
  isRead     Boolean       @default(false)
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([type])
  @@index([createdAt])
  @@map("alerts")
}

model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency String
  toCurrency   String
  rate         Decimal  @db.Decimal(10, 6)
  fetchedAt    DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([fromCurrency, toCurrency])
  @@index([expiresAt])
  @@map("exchange_rates")
}

enum SubscriptionPlan {
  FREE
  POS
  OPERATIONS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  INCOMPLETE
}

enum ProductionStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MovementType {
  PURCHASE
  PRODUCTION_IN
  PRODUCTION_OUT
  SALE
  ADJUSTMENT
  WASTE
}

enum SupplierOrderStatus {
  PENDING
  PLACED
  RECEIVED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  READY
  DELIVERED
  CANCELLED
}

enum AlertType {
  LOW_STOCK
  CRITICAL_STOCK
  ORDER_DUE
  PRODUCTION_DUE
  SYSTEM
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

// Phase 2 enums
enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum PaymentMethod {
  CASH
  QRIS
  GOPAY
  OVO
  DANA
  SHOPEEPAY
  BANK_TRANSFER
  STRIPE_CARD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

enum OrderSource {
  MANUAL
  STOREFRONT
  POS
  // Phase 5: aggregator channels
  GOFOOD
  GRABFOOD
  SHOPEEFOOD
  TOKOPEDIA
}

// Phase 3: Table management
enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

enum OrderItemStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

model Table {
  id                 String        @id @default(cuid())
  storeId            String
  label              String
  capacity           Int           @default(4)
  status             TableStatus   @default(AVAILABLE)
  reservationEnabled Boolean       @default(false)
  positionX          Int?
  positionY          Int?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  store              Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orders             Order[]
  reservations       Reservation[]

  @@unique([storeId, label])
  @@index([storeId])
  @@map("tables")
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Reservation {
  id           String            @id @default(cuid())
  storeId      String
  tableId      String?
  guestName    String
  guestPhone   String?
  guestEmail   String?
  partySize    Int               @default(1)
  scheduledAt  DateTime
  notes        String?
  status       ReservationStatus @default(PENDING)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  store        Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  table        Table?            @relation(fields: [tableId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([tableId])
  @@index([scheduledAt])
  @@map("reservations")
}

// =============================================================================
// PHASE 4: OPERATIONS LAYER
// =============================================================================

enum StaffRole {
  OWNER
  MANAGER
  CASHIER
  KITCHEN
}

model StaffMember {
  id              String     @id @default(cuid())
  storeId         String
  name            String
  email           String?
  role            StaffRole  @default(CASHIER)
  pin             String     // bcrypt hash — never store plaintext
  isActive        Boolean    @default(true)
  inviteStatus    String?    // "pending" | "accepted" | null
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  store           Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  shifts          Shift[]

  @@index([storeId])
  @@map("staff_members")
}

model Shift {
  id               String       @id @default(cuid())
  storeId          String
  staffMemberId    String
  openedAt         DateTime     @default(now())
  closedAt         DateTime?
  openingCash      Decimal      @db.Decimal(12, 2)
  closingCash      Decimal?     @db.Decimal(12, 2)
  expectedCash     Decimal?     @db.Decimal(12, 2)  // calculated from orders
  cashDifference   Decimal?     @db.Decimal(12, 2)  // closingCash - expectedCash
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  store            Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  staffMember      StaffMember  @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  orders           Order[]

  @@index([storeId])
  @@index([staffMemberId])
  @@index([openedAt])
  @@map("shifts")
}

// =============================================================================
// PHASE 5: AGGREGATOR + FINANCE
// =============================================================================

enum AggregatorPlatform {
  GOFOOD
  GRABFOOD
  SHOPEEFOOD
  TOKOPEDIA
}

model AggregatorConnection {
  id           String             @id @default(cuid())
  storeId      String
  platform     AggregatorPlatform
  displayName  String?            // e.g. "Warung Bahagia - GoFood"
  isActive     Boolean            @default(true)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  store        Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, platform])
  @@index([storeId])
  @@map("aggregator_connections")
}

// Raw inbound email audit log — keeps every forwarded email for debugging / re-parse
model AggregatorEmail {
  id           String             @id @default(cuid())
  storeId      String
  platform     AggregatorPlatform?
  fromAddress  String
  subject      String
  bodyText     String             @db.Text
  bodyHtml     String?            @db.Text
  parsedOrderId String?           // null if parsing failed or pending
  parseStatus  String             @default("pending") // pending | success | failed | manual
  parseError   String?
  createdAt    DateTime           @default(now())
  store        Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([parseStatus])
  @@map("aggregator_emails")
}

// =============================================================================
// AI IMPORT AGENT MODELS
// =============================================================================

model AIImportMemory {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  memoryType    String   // FIELD_MAPPING, TYPO_CORRECTION, CATEGORY_PATTERN, etc.
  sourcePattern String   // Original pattern (e.g., "Hrg Beli")
  targetMapping String   // What it maps to (e.g., "unitCost")
  entityType    String   // material, product, supplier, recipe
  confidence    Float    @default(0.5) // 0.0 - 1.0
  usageCount    Int      @default(1) // How many times used
  successCount  Int      @default(0) // How many times correct
  lastUsed      DateTime @default(now())
  userConfirmed Boolean  @default(false) // Did user explicitly confirm?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([storeId, memoryType, sourcePattern, entityType])
  @@index([storeId])
  @@index([memoryType])
  @@map("ai_import_memories")
}

model AIImportSession {
  id              String   @id @default(cuid())
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  fileName        String
  fileSize        Int      @default(0)
  rowCount        Int      @default(0)
  entityType      String? // Detected or specified entity type
  status          String   @default("pending") // pending, analyzing, preview, importing, completed, failed
  analysisResult  Json? // Full AI analysis result
  importResult    Json? // Import execution result
  aiCallCount     Int      @default(0)
  totalTokens     Int      @default(0)
  processingTimeMs Int? // Total processing time
  userCorrections Json? // What user changed from AI suggestions
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([storeId])
  @@index([status])
  @@map("ai_import_sessions")
}

// PHASE 1 -- Public Storefront
model Storefront {
  id              String   @id @default(cuid())
  storeId         String   @unique
  slug            String   @unique
  displayName     String
  tagline         String?
  description     String?
  logoUrl         String?
  heroImageUrl    String?
  themeColor      String   @default("#FF6B35")
  fontFamily      String   @default("Inter")
  
  whatsappNumber  String?
  instagramUrl    String?
  tiktokUrl       String?
  gofoodUrl       String?
  grabfoodUrl     String?
  shopeefoodUrl   String?
  googleMapsUrl   String?
  customLinks     Json?
  
  isPublished          Boolean  @default(false)
  acceptsOrders        Boolean  @default(false)
  acceptsReservations  Boolean  @default(false)
  openingHours         Json?
  viewCount       Int      @default(0)
  
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  menuCategories  MenuCategory[]
  menuItems       MenuItem[]
  orders          Order[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@map("storefronts")
}

model MenuCategory {
  id            String       @id @default(cuid())
  storefrontId  String
  name          String
  displayOrder  Int          @default(0)
  
  storefront    Storefront   @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
  items         MenuItem[]
  
  @@map("menu_categories")
}

model MenuItem {
  id              String       @id @default(cuid())
  storefrontId    String
  categoryId      String?
  productId       String?      // optional link to Product for inventory deduction
  name            String
  description     String?
  price           Decimal      @db.Decimal(12, 2)
  currency        String       @default("IDR")
  imageUrl        String?
  isAvailable     Boolean      @default(true)
  isFeatured      Boolean      @default(false)
  displayOrder    Int          @default(0)
  modifiers       Json?        // [{name, options: [{name, priceAdd}]}]
  
  storefront      Storefront    @relation(fields: [storefrontId], references: [id], onDelete: Cascade)
  category        MenuCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  product         Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  orderItems      OrderItem[]

  @@index([storefrontId])
  @@map("menu_items")
}

