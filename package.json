{
  "name": "epidom",
  "version": "2.8.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "prisma migrate deploy && tsx scripts/sync-changelog.ts && next build",
    "sync:changelog": "tsx scripts/sync-changelog.ts",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "postinstall": "prisma generate"
  },
