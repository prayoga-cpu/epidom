# Environment variables for Better-Auth
BETTER_AUTH_SECRET=generate-a-strong-random-secret-here
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend Email Configuration (https://resend.com)
# Get your API key from: https://resend.com/api-keys
# For testing, you can use onboarding@resend.dev as the sender
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM="EPIDOM <noreply@yourdomain.com>"

# Database connection URL
DATABASE_URL="sqlite:./dev.db"

# Vercel BLOB Storage
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

# Exchange Rate API (https://www.exchangerate-api.com/)
# Free tier: 1,500 requests/month
# Sign up at: https://app.exchangerate-api.com/sign-up
EXCHANGE_RATE_API_KEY="your-exchange-rate-api-key-here"
EXCHANGE_RATE_API_URL="https://v6.exchangerate-api.com/v6"

# Stripe Payment Configuration
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_your-secret-key-here"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-publishable-key-here"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret-here"

# Stripe Price IDs (from Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PRICE_ID_STARTER="price_test_starter"
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO="price_test_pro"

# Epidom Owner Configuration
# Email of the Epidom business owner who receives 80% of subscription revenue
EPIDOM_OWNER_EMAIL="owner@epidom.fr"

# Promotion Configuration
# End date for the New Year free PRO promotion (ISO 8601 format)
PROMO_END_DATE="2025-12-31T23:59:59Z"

# Feature Flags
NEXT_PUBLIC_FEATURE_LEGACY_INVENTORY=false

# ── Phase 2: Direct Ordering + QRIS ──────────────────────────────────────────

# Xendit (Indonesian payments: QRIS, GoPay, OVO, DANA, ShopeePay, bank transfer)
# Get keys from: https://dashboard.xendit.co/settings/developers
XENDIT_SECRET_KEY="xnd_development_your-secret-key"
XENDIT_WEBHOOK_TOKEN="your-xendit-callback-token"

# Fonnte (WhatsApp notifications via unofficial bridge)
# Get token from: https://fonnte.com/
FONNTE_API_TOKEN="your-fonnte-api-token"

# Inngest (background jobs: order routing, notification retries)
# Get keys from: https://app.inngest.com/
INNGEST_EVENT_KEY="your-inngest-event-key"
INNGEST_SIGNING_KEY="your-inngest-signing-key"

# WhatsApp Business API (future migration from Fonnte — stub only for now)
# WABA_PHONE_NUMBER_ID="your-waba-phone-number-id"
# WABA_ACCESS_TOKEN="your-waba-access-token"
