# Environment variables for Better-Auth
BETTER_AUTH_SECRET=generate-a-strong-random-secret-here
# Legacy fallback for BETTER_AUTH_SECRET (only read if that's unset)
NEXTAUTH_SECRET=generate-a-strong-random-secret-here
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (sign in with Google) — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Email shared for "owner" role checks (grants the admin dashboard).
# NEXT_PUBLIC_EPIDOM_OWNER_EMAIL takes precedence if set.
EPIDOM_OWNER_EMAIL=owner@yourdomain.com

# Resend Email Configuration (https://resend.com)
# Get your API key from: https://resend.com/api-keys
# For testing, you can use onboarding@resend.dev as the sender
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM="EPIDOM <noreply@yourdomain.com>"

# ── Database (Neon / Vercel Postgres) ────────────────────────────────────────
# Vercel injects these automatically when you link a Vercel Postgres database.
# For local dev, set both to your local postgres URL.

# Pooled connection — used by the app at runtime (goes through pgBouncer)
# Vercel Postgres key: POSTGRES_URL  /  Neon: pooler endpoint (-pooler in hostname)
DATABASE_URL="postgresql://neondb_owner:password@ep-xxx-pooler.region.aws.neon.tech/neondb?channel_binding=require&sslmode=require"

# Direct (non-pooled) connection — used ONLY by Prisma CLI for migrations
# Vercel Postgres key: POSTGRES_URL_NON_POOLING  /  Neon: direct endpoint (no -pooler)
# MUST be set in Vercel env vars or prisma migrate deploy will fail (P1012)
DIRECT_URL="postgresql://neondb_owner:password@ep-xxx.region.aws.neon.tech/neondb?channel_binding=require&sslmode=require"

# Vercel BLOB Storage
BLOB_READ_WRITE_TOKEN="your-vercel-blob-token"

# Exchange Rate API (https://www.exchangerate-api.com/)
# Free tier: 1,500 requests/month
# Sign up at: https://app.exchangerate-api.com/sign-up
EXCHANGE_RATE_API_KEY="your-exchange-rate-api-key-here"
EXCHANGE_RATE_API_URL="https://v6.exchangerate-api.com/v6"

# Stripe Payment Configuration
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_your-secret-key-here"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-publishable-key-here"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret-here"

# Stripe Price IDs (from Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PRICE_ID_STARTER="price_test_starter"
NEXT_PUBLIC_STRIPE_PRICE_ID_OPERATIONS="price_test_pro"
NEXT_PUBLIC_STRIPE_PRICE_ID_PRO="price_test_pro_legacy"

# Promotion Configuration
# End date for the New Year free PRO promotion (ISO 8601 format)
PROMO_END_DATE="2025-12-31T23:59:59Z"

# Feature Flags
NEXT_PUBLIC_FEATURE_LEGACY_INVENTORY=false

# Meta (Facebook) Pixel — https://business.facebook.com/events_manager
# Only loads client-side once the user grants marketing-cookie consent.
NEXT_PUBLIC_META_PIXEL_ID="your-meta-pixel-id"

# ── Phase 2: Direct Ordering + QRIS ──────────────────────────────────────────

# Xendit (Indonesian payments: QRIS, GoPay, OVO, DANA, ShopeePay, bank transfer)
# Get keys from: https://dashboard.xendit.co/settings/developers
XENDIT_SECRET_KEY="xnd_development_your-secret-key"
XENDIT_WEBHOOK_TOKEN="your-xendit-callback-token"

# Fonnte (WhatsApp notifications via unofficial bridge)
# Get token from: https://fonnte.com/
FONNTE_API_TOKEN="your-fonnte-api-token"

# Inngest (background jobs: order routing, notification retries)
# Get keys from: https://app.inngest.com/
INNGEST_EVENT_KEY="your-inngest-event-key"
INNGEST_SIGNING_KEY="your-inngest-signing-key"

# WhatsApp Business API (future migration from Fonnte — stub only for now)
# WABA_PHONE_NUMBER_ID="your-waba-phone-number-id"
# WABA_ACCESS_TOKEN="your-waba-access-token"

# OpenAI (parses aggregator order emails — GoFood/GrabFood/ShopeeFood/Tokopedia — into Order records)
OPENAI_API_KEY="sk-your-openai-api-key"

# Shared secret validating inbound email webhook requests (optional — only enforced if set)
EMAIL_WEBHOOK_SECRET="your-email-webhook-shared-secret"

# Shared secret required to call POST /api/admin/seed-demo (demo data seeding)
SEED_DEMO_SECRET="your-seed-demo-shared-secret"
